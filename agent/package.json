{
  "name": "estate-os-agent",
  "version": "1.0.0",
  "description": "Estate-OS 로컬 에이전트 — 네이버 부동산 프록시 (주거 IP 우회)",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc",
    "start": "electron dist/main.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "express": "^4.21.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.7.3"
  },
  "build": {
    "appId": "com.estateos.agent",
    "productName": "Estate-OS Agent",
    "artifactName": "Estate-OS-Agent-Setup.${ext}",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true,
      "installerLanguages": ["Korean"],
      "language": "1042"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/tray-icon.png"
    },
    "files": [
      "dist/**/*",
      "assets/**/*"
    ]
  }
}
